# ─── Fabric ────────────────────────────────────────────────
FABRIC_WORKSPACE_NAME=your-workspace-name
FABRIC_LAKEHOUSE_NAME=your_lakehouse_name

# ─── Azure AI Search ────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH-SERVICE.search.windows.net
AZURE_SEARCH_INDEX_NAME=tvlog-paragraph
AZURE_SEARCH_ADMIN_KEY=YOUR-SEARCH-ADMIN-KEY

# ─── Azure OpenAI ────────────────────────────────────────────
AOAI_ENDPOINT=https://YOUR-AOAI-RESOURCE.openai.azure.com
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AOAI_API_VERSION=2024-08-01-preview

# ─── Azure resource IDs (setup_mi_rbac.py / grant_search_rbac.py 用) ─────
AZURE_SUBSCRIPTION_ID=YOUR-SUBSCRIPTION-ID
AZURE_SEARCH_RG=your-search-resource-group
AZURE_SEARCH_NAME=your-search-service-name
AZURE_AOAI_RG=your-aoai-resource-group
AZURE_AOAI_ACCOUNT=your-aoai-account-name
